# orderstock — environment template (safe to commit; no real secrets)
# Copy to .env and fill in a strong SA password for the local Docker SQL Server sandbox.
#
# JDBC-style Prisma connection string (NOT ADO.NET). Reserved chars in the password
# ( : \ = ; / [ ] { } ) must be brace-escaped, e.g. password={Pa:ss;word}.
# SANDBOX ONLY during development — host must be localhost:1433 (the Docker container).
DATABASE_URL="sqlserver://localhost:1433;database=orderstock;user=sa;password=CHANGE_ME_Strong!Passw0rd;encrypt=true;trustServerCertificate=true"

# SA password for the Docker SQL Server sandbox (must match the password in DATABASE_URL
# and meet SQL Server complexity: 8+ chars, upper + lower + digit + symbol).
MSSQL_SA_PASSWORD="CHANGE_ME_Strong!Passw0rd"

# --- Auth (next-auth v5 / Auth.js) — Phase 03 ---
# AUTH_SECRET signs the JWT session. Generate with: openssl rand -base64 32
# (v5 name — NOT NEXTAUTH_SECRET). Keep the real value ONLY in .env (gitignored).
AUTH_SECRET="CHANGE_ME_run_openssl_rand_base64_32"
# Required so Auth.js trusts the host in non-Vercel / self-hosted deployments.
AUTH_TRUST_HOST=true
# Initial ADMIN password consumed ONCE by `pnpm tsx prisma/seed.ts`. If unset, the seed
# generates a random one and prints it to stdout for out-of-band delivery. NEVER commit a
# real value here; deliver it securely and change it after first login.
SEED_ADMIN_PASSWORD="CHANGE_ME_initial_admin_password"
